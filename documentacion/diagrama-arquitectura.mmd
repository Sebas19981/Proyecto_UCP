    W --> FC[index.php\nFront Controller / Router]

    FC --> AC[AuthController]
    FC --> HC[HomeController]
    FC --> PC[PanelController]
    FC --> ADC[AdminController]
    FC --> CC[ConsultaController]
    FC --> UC[UsuarioController]

    AC --> AM[AuthModel]
    HC --> DM[DevolucionModel]
