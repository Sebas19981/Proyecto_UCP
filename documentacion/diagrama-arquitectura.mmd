    PC --> DM
    ADC --> DM
    ADC --> CM[ConsultaModel]
    CC --> CM
    UC --> UM[UsuarioModel]

    AM --> DB[(MySQL)]
    PM --> DB
    DM --> DB
    CM --> DB
    UM --> DB

    AC --> RC[Google reCAPTCHA API]
    PC --> EH[EmailHelper / PHPMailer]
    ADC --> EH
    EH --> SMTP[SMTP Gmail]

    HC --> V1[Views/home/*]
    PC --> V2[Views/admin/panel_auxiliar.php]
    ADC --> V3[Views/admin/panel_administrador.php]
    CC --> V4[Views/admin/consulta.php]
